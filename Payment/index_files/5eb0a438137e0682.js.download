;!function(){try { var e="undefined"!=typeof globalThis?globalThis:"undefined"!=typeof global?global:"undefined"!=typeof window?window:"undefined"!=typeof self?self:{},n=(new e.Error).stack;n&&((e._debugIds|| (e._debugIds={}))[n]="626236e6-9e49-fcd3-a3df-90584e477994")}catch(e){}}();
(globalThis.TURBOPACK||(globalThis.TURBOPACK=[])).push(["object"==typeof document?document.currentScript:void 0,198925,e=>{"use strict";var a=e.i(843476),s=e.i(672379),t=e.i(360415),r=e.i(883264),o=e.i(223136);try{var i=window;i._sentryModuleMetadata=i._sentryModuleMetadata||{},i._sentryModuleMetadata[(new i.Error).stack]=Object.assign({},i._sentryModuleMetadata[(new i.Error).stack],{"_sentryBundlerPluginAppKey:laters-web":!0})}catch(e){}let n=[{question:{id:"7OKQq6",message:"What is buy now pay later for flights?"},answer:{id:"q8wdJ4",message:"Buy now pay later (BNPL) for flights lets you book your ticket today and split the cost into smaller payments over time. Instead of paying the full fare upfront, you can choose from providers like Afterpay, Klarna, or Affirm to pay in installments, often interest-free. Laters.com offers 40+ BNPL providers across 15+ countries, giving you more payment flexibility than any other flight booking site."}},{question:{id:"FqI9wW",message:"How does fly now pay later work?"},answer:{id:"WoV8mv",message:"Search for your flight on Laters.com, select your fare, and at checkout choose your preferred BNPL provider. Most providers split the cost into 4 interest-free payments over 6-8 weeks. Some, like Affirm, offer longer monthly plans of 3-12 months. Your flight is booked instantly. You receive a real airline ticket immediately, and your installments are managed by the BNPL provider."}},{question:{id:"5qkEYy",message:"Can you book flights with no credit check?"},answer:{id:"qhTEH1",message:"Yes. Several BNPL providers on Laters.com don't require a credit check. Afterpay, Zip, and Cash App Afterpay approve you without a hard credit inquiry. Klarna and Affirm perform a soft check only, which does not affect your credit score. Everyone deserves access to flexible flight payments regardless of credit history."}},{question:{id:"4GwAoS",message:"What airlines can you book with buy now pay later?"},answer:{id:"UVMhpz",message:"Laters.com offers buy now pay later across 650+ airlines worldwide, including budget carriers, full-service airlines, and regional operators. This includes airlines like JetBlue, Frontier, Spirit, Flair, Bonza, Air Peace, and hundreds more. Any flight available on Laters.com can be paid for with BNPL. There are no airline restrictions."}},{question:{id:"sPGKvs",message:"Can you use Afterpay, Klarna, or Affirm for flights?"},answer:{id:"foi3OA",message:"Yes. Laters.com accepts Afterpay (US, CA, AU, NZ), Klarna (US, CA, MX, AU, NZ, UK), and Affirm (US). Each provider offers different installment options: Afterpay splits into 4 payments, Klarna offers pay-in-4 or monthly plans, and Affirm provides 3-12 month financing. Choose the option that best fits your budget at checkout."}},{question:{id:"6PUg6p",message:"Can you pay for flights with Bitcoin or cryptocurrency?"},answer:{id:"j/9O+1",message:"Yes. Laters.com is one of the only flight booking sites that accepts cryptocurrency. Pay with Bitcoin, Ethereum, USDT, USDC, DAI, PYUSD, and 100+ other digital currencies. Use code FlyFurtherCrypto for 7.5% off crypto bookings. Your flight is booked instantly, just like paying with a credit card."}},{question:{id:"a+dULy",message:"Are there any hidden fees when booking with Laters.com?"},answer:{id:"Mbc7wu",message:"No. The price displayed on Laters.com includes all taxes, service charges, and booking fees. There are no surprise charges at checkout, no drip pricing, and no hidden extras. What you see is what you pay. If you choose a BNPL provider, your installment plan is clearly shown before you confirm, with no additional fees from Laters.com."}},{question:{id:"rh/ZiT",message:"Is it safe to book flights with Laters.com?"},answer:{id:"sQMSTQ",message:"Yes. Laters.com is a registered travel company operating in 10+ global markets. We are rated 4.7/5 on Trustpilot and 4.9/5 on Google Reviews. All payments are processed through secure, PCI-compliant payment gateways. Your flight tickets are real airline tickets, the same as booking directly with the airline. We also offer optional cancellation protection for added peace of mind."}},{question:{id:"md3TOh",message:"Do flight prices go up the more you search?"},answer:{id:"Q4UZXl",message:"This is a common myth. Airlines use dynamic pricing based on demand, seat availability, and booking timing, not your personal search history. Flight prices can change frequently, but clearing your cookies or using incognito mode won't get you a lower fare. The best strategy is to book when you find a price you're comfortable with, and use BNPL to spread the cost if the fare is higher than expected."}},{question:{id:"HA7wpf",message:"What is the cheapest day to book flights?"},answer:{id:"vlzKqM",message:"Studies show that Tuesday and Wednesday tend to have slightly lower average fares, and booking 1-3 months in advance for domestic flights (2-8 months for international) typically yields the best prices. However, prices vary by route, season, and demand. Rather than timing the market, consider using buy now pay later to lock in a good fare when you find one and pay over time."}}];try{var l=window;l._sentryModuleMetadata=l._sentryModuleMetadata||{},l._sentryModuleMetadata[(new l.Error).stack]=Object.assign({},l._sentryModuleMetadata[(new l.Error).stack],{"_sentryBundlerPluginAppKey:laters-web":!0})}catch(e){}function d({className:e,heading:i="Buy Now Pay Later Flights FAQ",description:l="Everything you need to know about booking flights with Laters.com.",items:d=n,headerless:c=!1}){let{_:m}=(0,t.useLingui)(),u=(0,a.jsx)(s.Accordion,{type:"single",collapsible:!0,className:"homepage-table mx-auto w-full max-w-3xl",children:d.map((e,t)=>{var r;return(0,a.jsx)(s.AccordionItem,{value:`faq-${t}`,className:"border-b-0",children:(0,a.jsxs)("div",{className:"border-b border-homepage-border/20 last:border-b-0",children:[(0,a.jsx)(s.AccordionTrigger,{showChevron:!0,className:"homepage-faq-trigger",children:(0,a.jsxs)("span",{className:"fl