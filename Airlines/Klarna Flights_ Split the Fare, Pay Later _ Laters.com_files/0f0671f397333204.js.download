            @keyframes woop-rig { 0% { transform: translateY(-110%) } 12% { transform: translateY(0) } 15% { transform: translateY(-2.5%) } 18% { transform: translateY(0) } 85% { transform: translateY(0) } 100% { transform: translateY(-115%) } }
            @keyframes woop-lights-fade { 0%, 13% { opacity: 0 } 22% { opacity: 1 } 80% { opacity: 1 } 88%, 100% { opacity: 0 } }
            @keyframes woop-beam-spin { from { transform: translate(-50%,-50%) rotate(0deg) } to { transform: translate(-50%,-50%) rotate(360deg) } }
            @keyframes woop-beam-pulse { from { opacity: 0.55; scale: 1 } to { opacity: 1; scale: 1.06 } }
            @keyframes woop-ball-sway { from { transform: rotate(-5deg) } to { transform: rotate(5deg) } }
            @keyframes woop-ball-spin { from { transform: rotate(0deg) } to { transform: rotate(360deg) } }
            @keyframes woop-wash { 0% { transform: translate(-12%,-8%) } 50% { transform: translate(12%,8%) } 100% { transform: translate(-12%,-8%) } }
            @keyframes woop-doge-float { from { transform: translateY(0) } to { transform: translateY(-140vh) } }
            @keyframes woop-doge-sway { from { transform: rotate(-9deg) translateX(-10px) } to { transform: rotate(9deg) translateX(10px) } }
            @keyframes woop-twinkle { from { opacity: 0.15; transform: scale(0.6) rotate(0deg) } to { opacity: 1; transform: scale(1.15) rotate(20deg) } }
            @keyframes woop-bop { from { transform: rotate(-3deg) scale(1) } to { transform: rotate(3deg) scale(1.07) } }
            @keyframes woop-count-pop { 0% { transform: scale(0) rotate(-20deg); opacity: 0 } 60% { transform: scale(1.25) rotate(8deg); opacity: 1 } 100% { transform: scale(1) rotate(6deg); opacity: 1 } }
            @keyframes woop-count-bob { from { translate: 0 0 } to { translate: 0 -14px } }
            @keyframes woop-plane { 0% { transform: translateX(-46vw) } 100% { transform: translateX(140vw) } }
            @keyframes woop-banner-wave { from { transform: rotate(-2deg) } to { transform: rotate(2deg) } }
            @keyframes fw-burst { 0% { transform: scale(0.12); opacity: 1 } 12% { opacity: 1 } 100% { transform: scale(1.15); opacity: 0 } }
